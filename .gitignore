# Byte-compiled / optimized Python files
__pycache__/
*.py[cod]
*$py.class

# Sphinx documentation output
docs/_build/

# Runtime artifacts and caches
.cache/
logs/
.pytest_cache/
*.log

# Virtual environment (if stored inside the project)
omix_env/
.env/
venv/
.venv/

# Distribution / packaging
dist/
build/
*.egg-info/

# macOS system file
.DS_Store

# IDE / editor folders
.vscode/
.idea/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Test and debug artifacts
.coverage
config.debug.yaml

# Coverage HTML report (generated by pytest-cov, coverage.py)
htmlcov/

# If you ever add mypy type checking
.mypy_cache/

# If you use ruff (linter/formatter) – often creates its own cache
.ruff_cache/

# Vim swap files
*.swp
*.swo
*~

# Emacs
\#*\#

# Merge conflict backups
*.orig

# pyenv version file (if you pin a Python version locally)
.python-version

# Local omix config overrides (if they exist)
config.local.yaml
*.local.yaml